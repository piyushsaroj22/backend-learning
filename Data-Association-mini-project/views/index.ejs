<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <div class="p-10 w-full min-h-screen bg-zinc-900 text-white">
      <h3 class="text-3xl mb-5 tracking-tighter">Create Account</h3>
      <form action="/register" method="post">
        <input
          class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-lg"
          type="text"
          placeholder="Name"
          name="name"
        />
        <input
          class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-lg"
          type="text"
          placeholder="Username"
          name="username"
        />
        <input
          class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-lg"
          type="password"
          placeholder="Password"
          name="password"
        />
        <input
          class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-lg"
          type="email"
          placeholder="Email"
          name="email"
        />
        <input
          class="px-3 py-2 outline-none bg-transparent border-2 border-zinc-800 rounded-lg"
          type="number"
          placeholder="Age"
          name="age"
        />
        <input
          class="px-5 py-2 bg-blue-500 rounded-lg"
          type="submit"
          value="Create Account"
        />
      </form>
      <h4 class="mt-5 text-sm text-zinc-400">
        If Already have an account ? <a class="text-blue-500" href="/login">Login</a>
    </div>
  </body>
</html>
