<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body>
    <div class="p-10 w-full min-h-screen bg-zinc-900 text-white">
      <div class="w-full flex justify-end">
        <a
          class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block"
          href="/logout"
          >Logout</a
        >
      </div>
      <div class="w-20 h-20 mb-2 rounded-lg overflow-hidden"><img class="w-full h-full object-cover rounded-lg" src="/images/uploads/<%= user.profilepic %>" alt="Profile Picture"></div>
      <h3 class="text-3xl">
        <span class="font-light">Hello</span>, <%= user.name %> 👋
      </h3>
      <h5 class="mb-5">you can create a new post.</h5>
      <form action="/post" method="post">
        <textarea
          class="w-1/3 p-3 resize-none bg-transparent border-2 border-zinc-700 rounded-lg outline-none block mb-3"
          name="content"
          placeholder="What's On Your Mind ?"
        ></textarea>
        <input
          class="px-3 py-2 bg-blue-500 rounded-lg block mb-3 mt-2 w-40 text-sm"
          type="submit"
          value="Create New Post"
        />
      </form>
      <div class="post mt-20">
        <h3 class="text-zinc-400">Your Posts.</h3>
        <div class="postcontainer mt-5">
            <% user.posts.reverse().forEach(function(post){ %>
                <div class="post w-1/3 p-4 mb-4 rounded-md border-[1px] border-zinc-700">
                    <h4 class="text-blue-500 mb-2">@<%= user.username %></h4>
                    <p class="text-sm tracking-tight">
                        <%= post.content %>
                    </p>
                    <small class="mt-2 inline-block"><%= post.likes.length  %> Likes</small>
                    <div class="btns flex gap-4 mt-2">
                        <a class="text-blue-500" href="/like/<%= post._id %>"><%= post.likes.indexOf(user._id) === -1 ? 'Like' : 'Unlike' %></a>
                        <a class="text-zinc-600" href="/edit/<%= post._id %>">edit</a>
                    </div>
                </div>
            <% }) %>
        </div>
      </div>
    </div>
  </body>
</html>
