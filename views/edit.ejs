<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-full bg-zinc-900 p-10 text-white">
        <div class="nav mb-7 text-blue-400">
            <a href="/read">Read</a>
        </div>
        <h1 class="text-3xl tracking-tighter mb-3">Update User</h1>
        <form action="/update/<%= user._id %>" method="post">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outline-none bg-transparent" name="name" type="text" placeholder="Name" value="<%= user.name %>">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outline-none bg-transparent" name="email" type="text" placeholder="Email"value="<%= user.email %>">
            <input class="px-5 py-2 border-2 border-zinc-800 rounded-lg outline-none bg-transparent" name="image" type="text" placeholder="Image URL"value="<%= user.image %>">
            <input class="px-5 py-2 bg-yellow-500 text-black rounded-lg ml-3" type="submit" value="Update User">
        </form>
    </div>
</body>
</html>